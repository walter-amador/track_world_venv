<?xml version="1.0"?>
<robot name="limo_sim" xmlns:xacro="http://ros.org/wiki/xacro">

  <!-- ================================================================
       DRIVE MODE — 'diff' (4WD skid steer) or 'ackermann' (front-steer)
       Pass via:  xacro limo_sim.urdf.xacro drive_mode:=ackermann
  ================================================================ -->
  <xacro:arg name="drive_mode" default="diff"/>
  <xacro:property name="DRIVE_MODE" value="$(arg drive_mode)"/>

  <!-- ================================================================
       GEOMETRY CONSTANTS — LIMO Pro proportions (slightly stylized)
  ================================================================ -->
  <xacro:property name="WHEEL_RADIUS"   value="0.05"/>
  <xacro:property name="WHEEL_WIDTH"    value="0.045"/>
  <xacro:property name="WHEEL_MASS"     value="0.2"/>
  <xacro:property name="WHEELBASE_HALF" value="0.10"/>   <!-- ±x distance from center -->
  <xacro:property name="TRACK_HALF"     value="0.085"/>  <!-- ±y distance from center -->

  <xacro:property name="BASE_Z"         value="0.075"/>  <!-- base_link height above ground -->
  <xacro:property name="WHEEL_Z_OFFSET" value="-0.025"/> <!-- wheel center relative to base_link -->

  <xacro:property name="CHASSIS_X"      value="0.32"/>
  <xacro:property name="CHASSIS_Y"      value="0.22"/>
  <xacro:property name="CHASSIS_Z"      value="0.06"/>

  <xacro:property name="HOOD_X"         value="0.22"/>
  <xacro:property name="HOOD_Y"         value="0.20"/>
  <xacro:property name="HOOD_Z"         value="0.07"/>

  <!-- ================================================================
       MATERIALS (RViz2)
  ================================================================ -->
  <material name="limo_white"><color rgba="0.92 0.92 0.92 1.0"/></material>
  <material name="limo_black"><color rgba="0.10 0.10 0.10 1.0"/></material>
  <material name="limo_dark_grey"><color rgba="0.20 0.20 0.22 1.0"/></material>
  <material name="limo_green"><color rgba="0.10 0.85 0.30 1.0"/></material>
  <material name="wheel_black"><color rgba="0.05 0.05 0.05 1.0"/></material>
  <material name="camera_lens"><color rgba="0.05 0.05 0.10 1.0"/></material>

  <!-- ================================================================
       ROOT FRAMES
  ================================================================ -->
  <link name="base_footprint"/>

  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${BASE_Z}" rpy="0 0 0"/>
  </joint>

  <!-- ================================================================
       BASE LINK — composite chassis: white lower deck + black upper hood
                   + tilted dark front cowl + side accents + antennas.
       Inertia approximated as solid box of CHASSIS dims + hood mass.
       Body mass ≈ 4.0 kg.
  ================================================================ -->
  <link name="base_link">
    <!-- Lower white deck -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="${CHASSIS_X} ${CHASSIS_Y} ${CHASSIS_Z}"/></geometry>
      <material name="limo_white"/>
    </visual>

    <!-- Upper black hood -->
    <visual>
      <origin xyz="-0.02 0 ${CHASSIS_Z/2 + HOOD_Z/2}" rpy="0 0 0"/>
      <geometry><box size="${HOOD_X} ${HOOD_Y} ${HOOD_Z}"/></geometry>
      <material name="limo_black"/>
    </visual>

    <!-- Tilted front cowl (tablet-style screen) -->
    <visual>
      <origin xyz="0.10 0 ${CHASSIS_Z/2 + 0.045}" rpy="0 -0.45 0"/>
      <geometry><box size="0.06 0.18 0.09"/></geometry>
      <material name="limo_dark_grey"/>
    </visual>

    <!-- Left green LED accent strip -->
    <visual>
      <origin xyz="0.06 ${CHASSIS_Y/2 + 0.001} 0.005" rpy="0 0 0"/>
      <geometry><box size="0.03 0.005 0.015"/></geometry>
      <material name="limo_green"/>
    </visual>
    <!-- Right green LED accent strip -->
    <visual>
      <origin xyz="0.06 ${-CHASSIS_Y/2 - 0.001} 0.005" rpy="0 0 0"/>
      <geometry><box size="0.03 0.005 0.015"/></geometry>
      <material name="limo_green"/>
    </visual>

    <!-- Left antenna -->
    <visual>
      <origin xyz="-0.07 0.05 ${CHASSIS_Z/2 + HOOD_Z + 0.03}" rpy="0 0 0"/>
      <geometry><cylinder radius="0.0035" length="0.06"/></geometry>
      <material name="limo_black"/>
    </visual>
    <!-- Right antenna -->
    <visual>
      <origin xyz="-0.07 -0.05 ${CHASSIS_Z/2 + HOOD_Z + 0.03}" rpy="0 0 0"/>
      <geometry><cylinder radius="0.0035" length="0.06"/></geometry>
      <material name="limo_black"/>
    </visual>

    <!-- Collision: single bounding box covering deck + hood -->
    <collision>
      <origin xyz="0 0 0.04" rpy="0 0 0"/>
      <geometry><box size="${CHASSIS_X} ${CHASSIS_Y} 0.14"/></geometry>
    </collision>

    <inertial>
      <origin xyz="0 0 0.03" rpy="0 0 0"/>
      <mass value="4.0"/>
      <!-- Solid box (0.32 x 0.22 x 0.14): ixx=m/12*(y²+z²), iyy=m/12*(x²+z²), izz=m/12*(x²+y²) -->
      <inertia ixx="0.022667" ixy="0" ixz="0"
               iyy="0.040667" iyz="0"
               izz="0.050267"/>
    </inertial>
  </link>

  <!-- ================================================================
       WHEEL MACRO — fixed-position spinning wheel
       Used for: all 4 wheels in 'diff' mode, rear 2 wheels in 'ackermann'.
       Joint spins around Y axis directly (no joint-origin rotation).
       Visual/collision rotate cylinder so its long axis aligns with Y.
  ================================================================ -->
  <xacro:macro name="fixed_wheel" params="prefix x y">
    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child  link="${prefix}_wheel_link"/>
      <origin xyz="${x} ${y} ${WHEEL_Z_OFFSET}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="0.005" friction="0.005"/>
    </joint>

    <link name="${prefix}_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
        <geometry><cylinder radius="${WHEEL_RADIUS}" length="${WHEEL_WIDTH}"/></geometry>
        <material name="wheel_black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
        <geometry><cylinder radius="${WHEEL_RADIUS}" length="${WHEEL_WIDTH}"/></geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="${WHEEL_MASS}"/>
        <!-- Cylinder rotated to spin about Y: principal axis is now Y.
             ixx=izz=m/12*(3r²+l²) = 0.000159
             iyy=m/2*r²            = 0.000250 -->
        <inertia ixx="0.000159" ixy="0" ixz="0"
                 iyy="0.000250" iyz="0"
                 izz="0.000159"/>
      </inertial>
    </link>

    <gazebo reference="${prefix}_wheel_link">
      <material>Gazebo/FlatBlack</material>
      <mu1>1.2</mu1>
      <mu2>1.0</mu2>
      <kp>1000000.0</kp>
      <kd>100.0</kd>
      <minDepth>0.001</minDepth>
      <maxVel>0.5</maxVel>
      <fdir1>1 0 0</fdir1>
    </gazebo>
  </xacro:macro>

  <!-- ================================================================
       STEERED WHEEL MACRO — 2-DOF: steer revolute + spin continuous.
       Used only for front 2 wheels in 'ackermann' mode.
  ================================================================ -->
  <xacro:macro name="steered_wheel" params="prefix x y">
    <!-- Steering link: tiny massless dummy that pivots about Z -->
    <joint name="${prefix}_steer_joint" type="revolute">
      <parent link="base_link"/>
      <child  link="${prefix}_steer_link"/>
      <origin xyz="${x} ${y} ${WHEEL_Z_OFFSET}" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="-0.6" upper="0.6" effort="50" velocity="3.0"/>
      <dynamics damping="0.3" friction="0.02"/>
    </joint>

    <link name="${prefix}_steer_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.2"/>
        <inertia ixx="0.0002" ixy="0" ixz="0"
                 iyy="0.0002" iyz="0"
                 izz="0.0002"/>
      </inertial>
    </link>

    <!-- Wheel link: spins about Y axis directly (no joint-origin rotation) -->
    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="${prefix}_steer_link"/>
      <child  link="${prefix}_wheel_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <dynamics damping="0.005" friction="0.005"/>
    </joint>

    <link name="${prefix}_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
        <geometry><cylinder radius="${WHEEL_RADIUS}" length="${WHEEL_WIDTH}"/></geometry>
        <material name="wheel_black"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="1.5707963 0 0"/>
        <geometry><cylinder radius="${WHEEL_RADIUS}" length="${WHEEL_WIDTH}"/></geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="${WHEEL_MASS}"/>
        <!-- Cylinder spins about Y: iyy=m/2*r², ixx=izz=m/12*(3r²+l²) -->
        <inertia ixx="0.000159" ixy="0" ixz="0"
                 iyy="0.000250" iyz="0"
                 izz="0.000159"/>
      </inertial>
    </link>

    <gazebo reference="${prefix}_wheel_link">
      <material>Gazebo/FlatBlack</material>
      <mu1>1.2</mu1>
      <mu2>1.0</mu2>
      <kp>1000000.0</kp>
      <kd>100.0</kd>
      <minDepth>0.001</minDepth>
      <maxVel>0.5</maxVel>
      <fdir1>1 0 0</fdir1>
    </gazebo>
  </xacro:macro>

  <!-- ================================================================
       FRONT WHEELS — steered in ackermann, fixed in diff
  ================================================================ -->
  <xacro:if value="${DRIVE_MODE == 'ackermann'}">
    <xacro:steered_wheel prefix="front_left"  x="${WHEELBASE_HALF}" y="${TRACK_HALF}"/>
    <xacro:steered_wheel prefix="front_right" x="${WHEELBASE_HALF}" y="${-TRACK_HALF}"/>
  </xacro:if>
  <xacro:if value="${DRIVE_MODE == 'diff'}">
    <xacro:fixed_wheel prefix="front_left"  x="${WHEELBASE_HALF}" y="${TRACK_HALF}"/>
    <xacro:fixed_wheel prefix="front_right" x="${WHEELBASE_HALF}" y="${-TRACK_HALF}"/>
  </xacro:if>

  <!-- REAR WHEELS — always fixed-position spinning -->
  <xacro:fixed_wheel prefix="rear_left"  x="${-WHEELBASE_HALF}" y="${TRACK_HALF}"/>
  <xacro:fixed_wheel prefix="rear_right" x="${-WHEELBASE_HALF}" y="${-TRACK_HALF}"/>

  <!-- ================================================================
       CAMERA — small dark protrusion at top of front cowl.
       camera_link is the URDF/visual frame (REP-103 ENU: x-forward).
       camera_optical_link is the optical frame used by image_raw
       (REP-103: x-right, y-down, z-forward).
  ================================================================ -->
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="camera_link"/>
    <origin xyz="0.135 0 0.10" rpy="0 0 0"/>
  </joint>

  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.02 0.06 0.025"/></geometry>
      <material name="camera_lens"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><box size="0.02 0.06 0.025"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.03"/>
      <inertia ixx="1e-5" ixy="0" ixz="0"
               iyy="1e-5" iyz="0"
               izz="1e-5"/>
    </inertial>
  </link>

  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child  link="camera_optical_link"/>
    <!-- Rotate URDF frame (x-fwd, y-left, z-up) → optical (x-right, y-down, z-fwd) -->
    <origin xyz="0 0 0" rpy="-1.5707963 0 -1.5707963"/>
  </joint>
  <link name="camera_optical_link"/>

  <!-- ================================================================
       CAMERA SENSOR PLUGIN — 30 FPS RGB at 640×480, 70° HFOV.
       Topics published:
         /camera/image_raw       sensor_msgs/Image
         /camera/camera_info     sensor_msgs/CameraInfo
  ================================================================ -->
  <gazebo reference="camera_link">
    <material>Gazebo/FlatBlack</material>
    <sensor type="camera" name="limo_camera_sensor">
      <update_rate>30.0</update_rate>
      <visualize>false</visualize>
      <always_on>true</always_on>
      <camera>
        <horizontal_fov>1.2217</horizontal_fov> <!-- 70° -->
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.02</near>
          <far>30.0</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.005</stddev>
        </noise>
      </camera>
      <plugin name="limo_camera_controller" filename="libgazebo_ros_camera.so">
        <ros>
          <remapping>~/image_raw:=/camera/image_raw</remapping>
          <remapping>~/camera_info:=/camera/camera_info</remapping>
        </ros>
        <camera_name>camera</camera_name>
        <frame_name>camera_optical_link</frame_name>
        <hack_baseline>0.0</hack_baseline>
      </plugin>
    </sensor>
  </gazebo>

  <!-- ================================================================
       BODY GAZEBO MATERIAL OVERRIDES
  ================================================================ -->
  <gazebo reference="base_link">
    <material>Gazebo/White</material>
    <mu1>0.5</mu1>
    <mu2>0.5</mu2>
  </gazebo>

  <!-- ================================================================
       DRIVE PLUGINS — chosen by DRIVE_MODE
  ================================================================ -->

  <!-- 4WD SKID-STEER: gazebo_ros_diff_drive supports multiple wheel pairs.
       Front and rear pairs share the same separation/diameter, so the
       plugin treats them as two parallel diff-drive axles. -->
  <xacro:if value="${DRIVE_MODE == 'diff'}">
    <gazebo>
      <plugin name="limo_diff_drive" filename="libgazebo_ros_diff_drive.so">
        <ros/>
        <update_rate>50</update_rate>
        <num_wheel_pairs>2</num_wheel_pairs>
        <left_joint>front_left_wheel_joint</left_joint>
        <right_joint>front_right_wheel_joint</right_joint>
        <left_joint>rear_left_wheel_joint</left_joint>
        <right_joint>rear_right_wheel_joint</right_joint>
        <wheel_separation>${TRACK_HALF*2}</wheel_separation>
        <wheel_separation>${TRACK_HALF*2}</wheel_separation>
        <wheel_diameter>${WHEEL_RADIUS*2}</wheel_diameter>
        <wheel_diameter>${WHEEL_RADIUS*2}</wheel_diameter>
        <max_wheel_torque>20</max_wheel_torque>
        <max_wheel_acceleration>2.0</max_wheel_acceleration>
        <command_topic>cmd_vel</command_topic>
        <odometry_topic>odom</odometry_topic>
        <odometry_frame>odom</odometry_frame>
        <robot_base_frame>base_footprint</robot_base_frame>
        <publish_odom>true</publish_odom>
        <publish_odom_tf>true</publish_odom_tf>
        <publish_wheel_tf>false</publish_wheel_tf>
      </plugin>
    </gazebo>
  </xacro:if>

  <!-- ACKERMANN: subscribes to /cmd_vel (geometry_msgs/Twist) and converts
       linear.x → wheel speed, angular.z → steering angle via wheelbase.
       NOTE: angular.z in cmd_vel is interpreted as target steering angle (rad),
       not yaw rate. Max ±0.6 rad (≈34°). -->
  <xacro:if value="${DRIVE_MODE == 'ackermann'}">
    <gazebo>
      <plugin name="limo_ackermann_drive" filename="libgazebo_ros_ackermann_drive.so">
        <ros/>
        <!-- 500 Hz keeps plugin timestep (2 ms) safely below closed-loop
             time constant (τ_cl = I/(D_mech+P) ≈ 5.5 ms at P=0.05).
             At 100 Hz the plugin was undersampled → oscillation → NaN. -->
        <update_rate>500.0</update_rate>

        <front_left_joint>front_left_wheel_joint</front_left_joint>
        <front_right_joint>front_right_wheel_joint</front_right_joint>
        <rear_left_joint>rear_left_wheel_joint</rear_left_joint>
        <rear_right_joint>rear_right_wheel_joint</rear_right_joint>
        <left_steering_joint>front_left_steer_joint</left_steering_joint>
        <right_steering_joint>front_right_steer_joint</right_steering_joint>

        <max_steer>0.6</max_steer>
        <max_speed>2.0</max_speed>

        <!-- Robot-specific geometry -->
        <wheel_radius>${WHEEL_RADIUS}</wheel_radius>
        <wheelbase>${WHEELBASE_HALF * 2}</wheelbase>
        <wheel_track>${TRACK_HALF * 2}</wheel_track>

        <!-- PID gains — tuned for wheel inertia 2.5e-4 kg·m², damping 0.005.
             Steer: P-only; steer joint damping=0.3 overdamps naturally, no D needed.
             Linear: P=0.05 is inside the stable window [0.027, 0.158] at 500 Hz;
                     I=0.5 eliminates steady-state error from joint friction;
                     D=0 avoids derivative spike on first PID call. -->
        <left_steering_pid_gain>2.0 0 0</left_steering_pid_gain>
        <left_steering_i_range>0 0</left_steering_i_range>
        <right_steering_pid_gain>2.0 0 0</right_steering_pid_gain>
        <right_steering_i_range>0 0</right_steering_i_range>
        <linear_velocity_pid_gain>0.05 0.5 0</linear_velocity_pid_gain>
        <linear_velocity_i_range>-2 2</linear_velocity_i_range>

        <command_topic>cmd_vel</command_topic>
        <odometry_topic>odom</odometry_topic>
        <odometry_frame>odom</odometry_frame>
        <robot_base_frame>base_footprint</robot_base_frame>

        <publish_odom>true</publish_odom>
        <publish_odom_tf>true</publish_odom_tf>
        <publish_wheel_tf>false</publish_wheel_tf>
        <publish_distance>false</publish_distance>
      </plugin>
    </gazebo>
  </xacro:if>

  <!-- ================================================================
       JOINT STATE PUBLISHER PLUGIN
       Publishes /joint_states for all wheel + steering joints so that
       robot_state_publisher can broadcast TF for them.
  ================================================================ -->
  <gazebo>
    <plugin name="limo_joint_state" filename="libgazebo_ros_joint_state_publisher.so">
      <ros>
        <remapping>~/out:=joint_states</remapping>
      </ros>
      <update_rate>30</update_rate>
      <joint_name>front_left_wheel_joint</joint_name>
      <joint_name>front_right_wheel_joint</joint_name>
      <joint_name>rear_left_wheel_joint</joint_name>
      <joint_name>rear_right_wheel_joint</joint_name>
      <xacro:if value="${DRIVE_MODE == 'ackermann'}">
        <joint_name>front_left_steer_joint</joint_name>
        <joint_name>front_right_steer_joint</joint_name>
      </xacro:if>
    </plugin>
  </gazebo>

</robot>
